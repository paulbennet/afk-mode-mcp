{
  "name": "afk-mode",
  "version": "1.0.0",
  "description": "AFK Mode — Bridge VS Code Copilot and mobile web app via MCP server",
  "type": "module",
  "scripts": {
    "dev:server": "tsx src/server/index.ts",
    "dev:webapp": "vite",
    "build:server": "tsup src/server/index.ts --format esm --out-dir dist",
    "build:webapp": "vite build",
    "build": "pnpm build:webapp && pnpm build:server",
    "start": "node dist/index.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.6.5",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^5.2.1",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/express": "^5.0.6",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}